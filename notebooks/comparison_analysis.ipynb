    "import pandas as pd\n",
    "import glob\n",
    "\n",
    "all_files = glob.glob(\"importance_*.csv\")\n",
    "\n",
    "li = []\n",
    "for filename in all_files:\n",
    "    df = pd.read_csv(filename, index_col=0)\n",
    "    li.apend(df)\n",
    "\n",
    "main_df = pd.concat(li, axis=0)"
